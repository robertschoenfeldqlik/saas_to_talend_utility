{
  "name": "saas-to-talend",
  "version": "1.0.0",
  "description": "Desktop application for generating Talend jobs from SaaS API specifications",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build && cd ../server && npm install --production",
    "build:electron": "electron-builder",
    "postinstall": "cd server && npm install && cd ../client && npm install"
  },
  "build": {
    "appId": "com.saastalend.app",
    "productName": "SaaS to Talend",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "client/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../engine/target/",
        "to": "engine/",
        "filter": ["*.jar"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  }
}
